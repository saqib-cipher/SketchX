<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:id="@+id/_main">
	<LinearLayout
		android:id="@+id/linear1"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/linear17"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginLeft="8dp"
			android:layout_marginTop="4dp"
			android:layout_marginRight="8dp"
			android:layout_marginBottom="4dp"
			android:gravity="center_vertical"
			android:orientation="horizontal"
			android:background="@drawable/shape"
			android:animateLayoutChanges="true">
			<EditText
				android:id="@+id/edittext1"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginLeft="8dp"
				android:layout_marginRight="5dp"
				android:padding="8dp"
				android:background="@android:color/transparent"
				android:textSize="14sp"
				android:hint="Search items"
				android:layout_weight="1"
				android:textColor="?attr/colorOnSurface" />
			<com.google.android.material.progressindicator.CircularProgressIndicator
				android:id="@+id/progressBar"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginRight="8dp"
				android:orientation="horizontal"
				app:indicatorSize="28dp"
				android:indeterminate="true"
				app:trackCornerRadius="2dp"
				app:indicatorTrackGapSize="2dp"
				android:visibility="gone" />
			<Button
				android:id="@+id/button3"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginRight="8dp"
				android:textSize="12sp"
				android:textColor="#111110"
				style="?attr/materialIconButtonStyle"
				app:icon="@drawable/clear" />
		</LinearLayout>
		<RelativeLayout
			android:id="@+id/relativelayout1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_gravity="center_horizontal|center_vertical">
			<androidx.recyclerview.widget.RecyclerView
				android:id="@+id/recyclerview1"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:paddingLeft="12dp"
				android:paddingTop="8dp"
				android:paddingRight="12dp"
				android:paddingBottom="8dp"
				android:layout_alignParentRight="true"
				android:layout_centerHorizontal="true"
				android:layout_alignParentLeft="true"
				tools:listitem="@layout/item" />
			<LinearLayout
				android:id="@+id/linear19"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginBottom="2dp"
				android:paddingLeft="8dp"
				android:paddingTop="4dp"
				android:paddingRight="8dp"
				android:paddingBottom="4dp"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical"
				android:background="@drawable/shape2"
				android:layout_centerInParent="true">
				<TextView
					android:id="@+id/textview1"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="TextView"
					android:textSize="11sp"
					android:textColor="?attr/colorOnSurfaceVariant" />
			</LinearLayout>
			<HorizontalScrollView
				android:id="@+id/scrollCategories"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_centerInParent="true"
				android:layout_alignBottom="@id/recyclerview1"
				android:layout_marginBottom="10dp"
				android:scrollbars="none">
				<com.google.android.material.button.MaterialButtonToggleGroup
					android:id="@+id/linear18"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:orientation="horizontal"
					app:singleSelection="true"
					app:selectionRequired="true"
					style="@style/Widget.Material3Expressive.MaterialButtonToggleGroup">
					<com.google.android.material.button.MaterialButton
						android:id="@+id/outline"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Outlined"
						style="@style/Widget.Material3Expressive.Button.OutlinedButton"
						android:textSize="12sp" />
					<com.google.android.material.button.MaterialButton
						android:id="@+id/filled"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Filled"
						android:textSize="12sp"
						style="@style/Widget.Material3Expressive.Button.OutlinedButton" />
					<com.google.android.material.button.MaterialButton
						android:id="@+id/round"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Round"
						android:textSize="12sp"
						style="@style/Widget.Material3Expressive.Button.OutlinedButton" />
					<com.google.android.material.button.MaterialButton
						android:id="@+id/sharp"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Sharp"
						android:textSize="12sp"
						style="@style/Widget.Material3Expressive.Button.OutlinedButton" />
					<com.google.android.material.button.MaterialButton
						android:id="@+id/twotone"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="Two Tone"
						android:textSize="12sp"
						style="@style/Widget.Material3Expressive.Button.OutlinedButton" />
				</com.google.android.material.button.MaterialButtonToggleGroup>
			</HorizontalScrollView>
			<com.google.android.material.button.MaterialButtonToggleGroup
				android:id="@+id/linear20"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginBottom="5dp"
				android:orientation="horizontal"
				android:visibility="gone"
				style="@style/Widget.Material3Expressive.MaterialButtonToggleGroup"
				android:layout_above="@id/linear19"
				android:layout_centerInParent="true">
				<Button
					android:id="@+id/cancel"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:textSize="12sp"
					style="@style/Widget.Material3Expressive.Button.IconButton"
					app:icon="@drawable/clear" />
				<Button
					android:id="@+id/impor"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="Import"
					android:textSize="12sp"
					style="@style/Widget.Material3Expressive.Button.IconButton"
					app:icon="@drawable/icon_arrow"
					android:textColor="?attr/colorOnPrimary"
					app:iconPadding="4dp" />
			</com.google.android.material.button.MaterialButtonToggleGroup>
			<Button
				android:id="@+id/button4"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginLeft="8dp"
				android:layout_marginBottom="10dp"
				android:textSize="12sp"
				android:textColor="#111110"
				app:icon="@drawable/imp"
				style="@style/Widget.Material3Expressive.Button.IconButton"
				android:layout_alignBottom="@id/recyclerview1"
				android:layout_alignParentLeft="true" />
			<Button
				android:id="@+id/button5"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginRight="8dp"
				android:layout_marginBottom="10dp"
				android:textSize="12sp"
				android:textColor="#111110"
				style="@style/Widget.Material3Expressive.Button.IconButton"
				app:icon="@drawable/icon_settings_round"
				android:layout_alignParentRight="true"
				android:layout_alignBottom="@id/recyclerview1" />
		</RelativeLayout>
	</LinearLayout>
</LinearLayout>
