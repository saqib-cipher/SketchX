<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:id="@+id/_main">
	<LinearLayout
		android:id="@+id/linear1"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/linear5"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:gravity="center_vertical"
			android:orientation="horizontal">
			<LinearLayout
				android:id="@+id/linear2"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="1dp"
				android:orientation="vertical"
				android:layout_weight="1">
				<TextView
					android:id="@+id/textview2"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginLeft="10dp"
					android:text="Select a Project"
					tools:replace="android:textSize"
					android:textAppearance="@style/TextAppearance.Material3.TitleLarge" />
				<TextView
					android:id="@+id/textview1"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginLeft="10dp"
					android:paddingTop="2dp"
					android:text="Fix errors, Generate layout and codes"
					android:alpha="0.5"
					tools:replace="android:textSize"
					android:textAppearance="?attr/textAppearanceLabelSmall" />
			</LinearLayout>
			<Button
				android:id="@+id/fille"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginRight="8dp"
				android:text="Gemini 2.5 Flash"
				style="@style/Widget.Material3Expressive.Button.OutlinedButton"
				tools:replace="android:textSize"
				android:textAppearance="?attr/textAppearanceLabelLarge" />
		</LinearLayout>
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/cardview1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginLeft="8dp"
			android:layout_marginTop="10dp"
			android:layout_marginRight="8dp"
			android:layout_marginBottom="2dp"
			style="@style/Widget.Material3.CardView.Filled">
			<LinearLayout
				android:id="@+id/linear19"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical">
				<TextView
					android:id="@+id/textview5"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:paddingTop="8dp"
					android:paddingRight="8dp"
					android:paddingBottom="2dp"
					android:text="Select Project:"
					android:layout_gravity="left"
					tools:replace="android:textSize"
					android:textAppearance="?attr/textAppearanceLabelMedium" />
				<LinearLayout
					android:id="@+id/linear20"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_vertical"
					android:orientation="horizontal"
					android:animateLayoutChanges="true">
					<androidx.cardview.widget.CardView
						android:id="@+id/cardview2"
						android:layout_width="50dp"
						android:layout_height="50dp"
						android:layout_marginLeft="4dp"
						android:layout_marginTop="2dp"
						android:layout_marginBottom="2dp"
						app:cardElevation="0dp"
						app:cardCornerRadius="12dp"
						android:focusable="true">
						<RelativeLayout
							android:id="@+id/relativelayout1"
							android:layout_width="match_parent"
							android:layout_height="match_parent">
							<ImageView
								android:id="@+id/imageview1"
								android:layout_width="match_parent"
								android:layout_height="match_parent"
								android:src="@drawable/default_image"
								android:scaleType="centerInside"
								android:layerType="software" />
							<TextView
								android:id="@+id/num"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:paddingLeft="4dp"
								android:paddingRight="4dp"
								android:background="@drawable/ShapeGl"
								android:gravity="center_horizontal|center_vertical"
								android:text="TextView"
								android:textSize="10sp"
								android:layout_alignParentBottom="true"
								android:layout_alignBottom="@id/imageview1" />
						</RelativeLayout>
					</androidx.cardview.widget.CardView>
					<LinearLayout
						android:id="@+id/linear21"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:layout_marginLeft="4dp"
						android:gravity="center_vertical"
						android:orientation="vertical"
						android:layout_weight="1">
						<TextView
							android:id="@+id/name"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="TextView"
							android:textSize="16sp" />
						<TextView
							android:id="@+id/packages"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginTop="2dp"
							android:text="TextView"
							android:textSize="12sp" />
					</LinearLayout>
					<Button
						android:id="@+id/replace"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginRight="4dp"
						android:textSize="12sp"
						android:textColor="#111110"
						style="@style/Widget.Material3Expressive.Button.IconButton"
						app:icon="@drawable/replace" />
				</LinearLayout>
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
		<RelativeLayout
			android:id="@+id/relativelayout2"
			android:layout_width="match_parent"
			android:layout_height="match_parent">
			<LinearLayout
				android:id="@+id/linear23"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:orientation="vertical">
				<androidx.recyclerview.widget.RecyclerView
					android:id="@+id/recyclerview1"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_marginBottom="60dp"
					android:padding="5dp"
					tools:listitem="@layout/chat" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear22"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginLeft="8dp"
				android:layout_marginTop="2dp"
				android:layout_marginRight="8dp"
				android:layout_marginBottom="8dp"
				android:padding="2dp"
				android:background="@drawable/shape2"
				android:gravity="center_vertical"
				android:orientation="horizontal"
				android:layout_alignBottom="@id/linear23">
				<Button
					android:id="@+id/button1"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:textSize="12sp"
					app:icon="@drawable/clear"
					style="@style/Widget.Material3Expressive.Button.IconButton" />
				<EditText
					android:id="@+id/edittext1"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:background="@android:color/transparent"
					android:textSize="14sp"
					android:hint="Enter Something "
					android:layout_weight="1"
					android:inputType="textMultiLine"
					android:scrollbars="vertical"
					android:overScrollMode="always"
					android:maxLines="8"
					android:ellipsize="end"
					android:gravity="top|start"
					android:scrollHorizontally="false" />
				<com.google.android.material.loadingindicator.LoadingIndicator
					android:id="@+id/loading_indicator2"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					style="@style/Widget.Material3.LoadingIndicator.Contained" />
				<Button
					android:id="@+id/button2"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:padding="8dp"
					android:textSize="12sp"
					app:icon="@drawable/icon_send_round"
					style="@style/Widget.Material3Expressive.Button.IconButton" />
			</LinearLayout>
			<LinearLayout
				android:id="@+id/ln_2"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:gravity="right|center_vertical"
				android:orientation="horizontal"
				android:animateLayoutChanges="true"
				android:layout_above="@id/linear22">
				<Button
					android:id="@+id/button3"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginLeft="8dp"
					android:layout_marginRight="5dp"
					android:padding="8dp"
					android:textSize="12sp"
					app:icon="@drawable/icon_che"
					style="@style/Widget.Material3Expressive.Button.IconButton.Tonal" />
				<HorizontalScrollView
					android:id="@+id/hscroll1"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_above="@id/linear22">
					<com.google.android.material.chip.ChipGroup
						android:id="@+id/linear24"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:orientation="horizontal"
						app:singleSelection="true"
						app:selectionRequired="true">
						<com.google.android.material.chip.Chip
							android:id="@+id/Normal"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="Normal Convo"
							android:textSize="12sp"
							style="@style/Widget.Material3.Chip.Filter"
							android:checked="true"
							app:checkedIconTint="?attr/colorOnSecondaryContainer"
							android:textColor="?attr/colorOnSecondaryContainer" />
						<com.google.android.material.chip.Chip
							android:id="@+id/LastEror"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="Compilation Err"
							android:textSize="12sp"
							style="@style/Widget.Material3.Chip.Filter"
							app:checkedIconTint="?attr/colorOnSecondaryContainer"
							android:textColor="?attr/colorOnSecondaryContainer" />
						<com.google.android.material.chip.Chip
							android:id="@+id/WholeSource"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="App Source"
							android:textSize="12sp"
							style="@style/Widget.Material3.Chip.Filter"
							app:checkedIconTint="?attr/colorOnSecondaryContainer"
							android:textColor="?attr/colorOnSecondaryContainer" />
						<com.google.android.material.chip.Chip
							android:id="@+id/AddNew"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:text="Add New"
							android:textSize="12sp"
							style="@style/Widget.Material3.Chip.Filter"
							app:checkedIconTint="?attr/colorOnSecondaryContainer"
							android:textColor="?attr/colorOnSecondaryContainer" />
					</com.google.android.material.chip.ChipGroup>
				</HorizontalScrollView>
			</LinearLayout>
		</RelativeLayout>
	</LinearLayout>
</LinearLayout>
