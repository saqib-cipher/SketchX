<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:id="@+id/_main">
	<LinearLayout
		android:id="@+id/linear1"
		android:layout_width="match_parent"
		android:layout_height="550dp"
		android:paddingLeft="2dp"
		android:paddingTop="2dp"
		android:paddingRight="2dp"
		android:paddingBottom="16dp"
		android:gravity="center_horizontal"
		android:orientation="vertical">
		<LinearLayout
			android:id="@+id/linear2"
			android:layout_width="60dp"
			android:layout_height="6dp"
			android:layout_marginTop="8dp"
			android:layout_marginBottom="8dp"
			android:padding="8dp"
			android:orientation="horizontal"
			android:layout_gravity="center_horizontal|center_vertical"
			android:background="@drawable/shape" />
		<TextView
			android:id="@+id/textview2"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginBottom="2dp"
			android:text="Status:"
			android:textColor="?colorOnSurfaceVariant"
			tools:replace="android:textSize"
			android:textAppearance="?attr/textAppearanceLabelMedium" />
		<TextView
			android:id="@+id/textview1"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginBottom="8dp"
			android:padding="8dp"
			android:textColor="?attr/colorOnSurface"
			tools:replace="android:textSize"
			android:textAppearance="?attr/textAppearanceLabelMedium" />
		<TextView
			android:id="@+id/textview3"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginBottom="2dp"
			android:text="Location:"
			android:textColor="?colorOnSurfaceVariant"
			tools:replace="android:textSize"
			android:textAppearance="?attr/textAppearanceLabelMedium" />
		<com.google.android.material.button.MaterialButtonToggleGroup
			android:id="@+id/linear18"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginBottom="10dp"
			android:orientation="horizontal"
			app:singleSelection="true"
			app:selectionRequired="true"
			style="@style/Widget.Material3Expressive.MaterialButtonToggleGroup"
			android:layout_centerInParent="true"
			android:layout_alignBottom="@id/recyclerview1">
			<com.google.android.material.button.MaterialButton
				android:id="@+id/skproj"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Sk Project"
				style="@style/Widget.Material3Expressive.Button.OutlinedButton"
				tools:replace="android:textSize"
				android:textAppearance="?attr/textAppearanceLabelLarge" />
			<com.google.android.material.button.MaterialButton
				android:id="@+id/fille"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Device Local"
				style="@style/Widget.Material3Expressive.Button.OutlinedButton"
				tools:replace="android:textSize"
				android:textAppearance="?attr/textAppearanceLabelLarge" />
		</com.google.android.material.button.MaterialButtonToggleGroup>
		<TextView
			android:id="@+id/textview6"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="Format:"
			android:textColor="?colorOnSurfaceVariant"
			tools:replace="android:textSize"
			android:textAppearance="?attr/textAppearanceLabelMedium" />
		<com.google.android.material.button.MaterialButtonToggleGroup
			android:id="@+id/linear24"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginBottom="10dp"
			android:orientation="horizontal"
			app:singleSelection="true"
			app:selectionRequired="true"
			style="@style/Widget.Material3Expressive.MaterialButtonToggleGroup"
			android:layout_centerInParent="true"
			android:layout_alignBottom="@id/recyclerview1">
			<com.google.android.material.button.MaterialButton
				android:id="@+id/icXml"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="XML"
				style="@style/Widget.Material3Expressive.Button.OutlinedButton"
				tools:replace="android:textSize"
				android:textAppearance="?attr/textAppearanceLabelLarge" />
			<com.google.android.material.button.MaterialButton
				android:id="@+id/button2"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="PNG"
				android:textSize="12sp"
				style="@style/Widget.Material3Expressive.Button.OutlinedButton"
				android:textAppearance="?attr/textAppearanceLabelLarge" />
		</com.google.android.material.button.MaterialButtonToggleGroup>
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/cardview1"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginLeft="8dp"
			android:layout_marginRight="8dp"
			android:layout_marginBottom="2dp"
			style="@style/Widget.Material3.CardView.Filled">
			<LinearLayout
				android:id="@+id/linear19"
				android:layout_width="match_parent"
				android:layout_height="match_parent"
				android:gravity="center_horizontal|center_vertical"
				android:orientation="vertical">
				<TextView
					android:id="@+id/textview5"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:paddingTop="8dp"
					android:paddingRight="8dp"
					android:paddingBottom="2dp"
					android:text="Select Project:"
					android:textColor="?colorOnSurfaceVariant"
					android:layout_gravity="left"
					tools:replace="android:textSize"
					android:textAppearance="?attr/textAppearanceLabelMedium" />
				<LinearLayout
					android:id="@+id/linear20"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:gravity="center_vertical"
					android:orientation="horizontal"
					android:animateLayoutChanges="true">
					<androidx.cardview.widget.CardView
						android:id="@+id/cardview2"
						android:layout_width="50dp"
						android:layout_height="50dp"
						android:layout_marginLeft="4dp"
						android:layout_marginTop="2dp"
						android:layout_marginBottom="2dp"
						app:cardElevation="0dp"
						app:cardCornerRadius="12dp"
						android:clickable="true"
						android:focusable="true">
						<RelativeLayout
							android:id="@+id/relativelayout1"
							android:layout_width="match_parent"
							android:layout_height="match_parent">
							<ImageView
								android:id="@+id/imageview1"
								android:layout_width="match_parent"
								android:layout_height="match_parent"
								android:src="@drawable/default_image"
								android:scaleType="centerInside"
								android:layerType="software" />
							<TextView
								android:id="@+id/num"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:paddingLeft="4dp"
								android:paddingRight="4dp"
								android:gravity="center_horizontal|center_vertical"
								android:text="TextView"
								android:textSize="10sp"
								android:background="@drawable/shapegl"
								android:textColor="?attr/colorOnSurface"
								android:layout_alignParentBottom="true"
								android:layout_alignBottom="@id/imageview1" />
						</RelativeLayout>
					</androidx.cardview.widget.CardView>
					<LinearLayout
						android:id="@+id/linear21"
						android:layout_width="wrap_content"
						android:layout_height="match_parent"
						android:layout_marginLeft="4dp"
						android:gravity="center_vertical"
						android:orientation="vertical"
						android:layout_weight="1">
						<TextView
							android:id="@+id/name"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="TextView"
							android:textSize="16sp"
							android:textColor="?attr/colorOnSurface" />
						<TextView
							android:id="@+id/packages"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:layout_marginTop="2dp"
							android:text="TextView"
							android:textSize="12sp"
							android:textColor="?attr/colorOnSurfaceVariant" />
					</LinearLayout>
					<Button
						android:id="@+id/replace"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginRight="4dp"
						android:textSize="12sp"
						android:textColor="#111110"
						style="@style/Widget.Material3Expressive.Button.IconButton"
						app:icon="@drawable/replace" />
				</LinearLayout>
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/cardview3"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginLeft="8dp"
			android:layout_marginTop="2dp"
			android:layout_marginRight="8dp"
			style="@style/Widget.Material3.CardView.Filled">
			<LinearLayout
				android:id="@+id/linear25"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="vertical">
				<TextView
					android:id="@+id/textview7"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:paddingLeft="8dp"
					android:paddingTop="8dp"
					android:paddingRight="8dp"
					android:paddingBottom="2dp"
					android:text="Local path:"
					android:textColor="?colorOnSurfaceVariant"
					tools:replace="android:textSize"
					android:textAppearance="?attr/textAppearanceLabelMedium" />
				<com.google.android.material.textfield.TextInputLayout
					android:id="@+id/textinputlayout1"
					android:layout_width="match_parent"
					android:layout_height="match_parent"
					android:layout_marginLeft="4dp"
					android:layout_marginRight="4dp"
					android:layout_marginBottom="8dp"
					style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
					app:helperText="Example:/storage/emulated/0/Download/">
					<EditText
						android:id="@+id/edittext1"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:textSize="12sp"
						android:hint="Path location " />
				</com.google.android.material.textfield.TextInputLayout>
				<com.google.android.material.button.MaterialButtonGroup
					android:id="@+id/linear28"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginRight="5dp"
					android:padding="2dp"
					android:orientation="horizontal"
					android:layout_gravity="right">
					<Button
						android:id="@+id/button5"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="Remember"
						android:textSize="12sp"
						app:materialSizeOverlay="@style/SizeOverlay.Material3Expressive.Button.Xsmall"
						android:checkable="true"
						style="@style/Widget.Material3Expressive.Button.OutlinedButton" />
					<Button
						android:id="@+id/button6"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:padding="8dp"
						android:text="Paste"
						android:textSize="12sp"
						app:materialSizeOverlay="@style/SizeOverlay.Material3Expressive.Button.Xsmall"
						style="@style/Widget.Material3Expressive.Button" />
				</com.google.android.material.button.MaterialButtonGroup>
			</LinearLayout>
		</com.google.android.material.card.MaterialCardView>
		<LinearLayout
			android:id="@+id/linear26"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:orientation="vertical"
			android:layout_weight="1" />
		<com.google.android.material.button.MaterialButtonGroup
			android:id="@+id/linear27"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="8dp"
			android:orientation="horizontal"
			style="@style/Widget.Material3Expressive.MaterialButtonGroup">
			<Button
				android:id="@+id/button3"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="Cancel"
				android:layout_weight="1"
				style="@style/Widget.Material3Expressive.Button.TonalButton"
				tools:replace="android:textSize"
				android:textAppearance="?attr/textAppearanceLabelLarge" />
			<Button
				android:id="@+id/button4"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:padding="8dp"
				android:text="Save"
				android:layout_weight="2"
				style="@style/Widget.Material3Expressive.Button"
				tools:replace="android:textSize"
				android:textAppearance="?attr/textAppearanceLabelLarge" />
		</com.google.android.material.button.MaterialButtonGroup>
	</LinearLayout>
</LinearLayout>
